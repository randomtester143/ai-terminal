{
    "cleanUrls": true,
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "X-Frame-Options", "value": "DENY" },
                { "key": "Referrer-Policy", "value": "no-referrer" }
            ]
        }
    ],
    "routes": [
        {
            "src": "^/api/session/create/(.*)",
            "dest": "/api/session/create"
        },
        {
            "src": "^/api/session/delete$",
            "dest": "/api/session/delete"
        },
        {
            "src": "^/api/ai/(.*)",
            "dest": "/api/ai"
        }
    ]
}